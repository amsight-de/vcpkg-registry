--- /dev/null
+++ b/cmake/config-cxx-config.cmake.in
@@ -0,0 +1,13 @@
+@PACKAGE_INIT@
+
+include(CMakeFindDependencyMacro)
+
+# Find required dependencies
+find_dependency(nlohmann_json CONFIG REQUIRED)
+find_dependency(yaml-cpp CONFIG REQUIRED)
+find_dependency(pugixml CONFIG REQUIRED)
+
+# Include the targets file
+include("${CMAKE_CURRENT_LIST_DIR}/config-cxx-targets.cmake")
+
+check_required_components(config-cxx)
